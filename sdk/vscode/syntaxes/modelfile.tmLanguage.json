{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Modelfile",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.modelfile",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.modelfile",
          "match": "\\b(?i:(FROM|SYSTEM|TEMPLATE|PARAMETER|LICENSE|ADAPTER|MESSAGE|DRAFT|REQUIRES))\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.modelfile",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.modelfile",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.modelfile",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "string.unquoted.heredoc.modelfile",
          "begin": "\"{3}",
          "end": "\"{3}"
        }
      ]
    }
  },
  "scopeName": "source.modelfile"
}
